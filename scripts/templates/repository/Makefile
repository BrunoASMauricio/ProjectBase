define _DEP_RAW
$$LINK_DEPENDENCIES$$
endef

_PUB_INCS  := $(strip $(subst $(_NL), ,$(_PUB_RAW)))
_PRIV_INCS := $(strip $(subst $(_NL), ,$(_PRIV_RAW)))
_TEST_INCS := $(strip $(subst $(_NL), ,$(_TEST_RAW)))
_DEP_NAMES := $(strip $(subst $(_NL), ,$(_DEP_RAW)))

_INC_FLAGS      := $(foreach d,$(_PUB_INCS) $(_PRIV_INCS),-I$(d))
_TEST_INC_FLAGS := $(foreach d,$(_PUB_INCS) $(_PRIV_INCS) $(_TEST_INCS),-I$(d))
_DEP_LIBS       := $(foreach n,$(_DEP_NAMES),$(PROJ_LIB_PATH)/lib$(n).a)

_REPO_LIB := $(PROJ_LIB_PATH)/lib$(REPO_NAME)_lib.a
_OBJ_DIR  := $(REPO_BUILD_PATH)/objs

# Per-repo build spec defaults (overridden by pb_build_spec.mk when present)
