-include $(REPO_BUILD_PATH)/pb_build_spec.mk

# Assemble compiler flag sets
_ALL_CFLAGS  := $(CFLAGS) $(_INC_FLAGS) $(REP_CFLAGS)
_LIB_CFLAGS  := $(_ALL_CFLAGS) $(REP_LIB_CFLAGS)
_EXE_CFLAGS  := $(_ALL_CFLAGS) $(REP_EXE_CFLAGS)
_TEST_CFLAGS := $(CFLAGS) $(_TEST_INC_FLAGS) $(REP_CFLAGS) $(REP_TEST_CFLAGS)

# Ensure output directories exist
$(shell mkdir -p $(PROJ_LIB_PATH) $(REPO_EXEC_PATH) $(REPO_TESTS_PATH))

# ---------------------------------------------------------------------------
# Static library from source files
# ---------------------------------------------------------------------------
_REPO_OBJS :=

define _SRC_OBJ_RULE
_REPO_OBJS += $(_OBJ_DIR)/$(basename $(notdir $(1))).o
$(_OBJ_DIR)/$(basename $(notdir $(1))).o: $(1)
	$(CC) $(_LIB_CFLAGS) -c $$< -o $$@
endef

ifneq ($(REPO_SOURCES),)
$(shell mkdir -p $(_OBJ_DIR))
$(foreach s,$(REPO_SOURCES),$(eval $(call _SRC_OBJ_RULE,$(s))))
$(_REPO_LIB): $(_REPO_OBJS)
	$(AR) rcs $@ $^
endif

# ---------------------------------------------------------------------------
# Executables
# ---------------------------------------------------------------------------
define _EXEC_RULE
$(REPO_EXEC_PATH)/$(1): $(EXEC_$(1)_SRC) $(if $(REPO_SOURCES),$(_REPO_LIB))
	$(CC) $(_EXE_CFLAGS) $(EXEC_$(1)_FLAGS) $(EXEC_$(1)_SRC) \
	    -Wl,--whole-archive $(if $(REPO_SOURCES),$(_REPO_LIB)) $(_DEP_LIBS) \
	    -Wl,--no-whole-archive -o $$@
endef

$(foreach e,$(REPO_EXECS),$(eval $(call _EXEC_RULE,$(e))))

# ---------------------------------------------------------------------------
# Tests
